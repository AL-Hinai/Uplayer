{
  "name": "uplayer",
  "version": "1.0.0",
  "description": "Uplayer - Simple CLI torrent player. Just search and play movies instantly using WebTorrent",
  "main": "uplayer.js",
  "bin": {
    "uplayer": "./uplayer.js"
  },
  "scripts": {
    "start": "node uplayer.js",
    "start:bun": "bun run uplayer.js",
    "web": "node server.js",
    "test": "npm run test:core && npm run test:recommendations && npm run test:lifecycle && npm run test:api-contract && npm run test:player-link && npm run test:player-html && npm run test:cast-tv && npm run test:vlc-link",
    "test:core": "node tests/core-services.test.js",
    "test:recommendations": "node tests/recommendation-engine.test.js",
    "test:api-contract": "node tests/api-contract.test.js",
    "test:lifecycle": "node tests/stream-lifecycle.test.js",
    "test:player-link": "node tests/open-active-player.test.js",
    "test:player-html": "node tests/native-player-html.test.js",
    "test:cast-tv": "node tests/cast-tv-modal.test.js",
    "test:vlc-link": "node tests/open-vlc-target.test.js",
    "test:stream-speed": "node test-stream-speed.js",
    "build": "pkg . --out-path dist",
    "build:all": "pkg . --targets node18-linux-x64,node18-win-x64,node18-macos-x64 --out-path dist",
    "build:linux": "pkg . --targets node18-linux-x64 --out-path dist",
    "build:win": "pkg . --targets node18-win-x64 --out-path dist",
    "build:macos": "pkg . --targets node18-macos-x64 --out-path dist",
    "install:bun": "bun install",
    "install:npm": "npm install"
  },
  "keywords": [
    "webtorrent",
    "streaming",
    "movies",
    "torrent",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "chalk": "^4.1.2",
    "cheerio": "^1.0.0-rc.12",
    "cli-progress": "^3.12.0",
    "commander": "^11.1.0",
    "express": "^4.22.1",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "inquirer": "^8.2.6",
    "open": "^8.4.2",
    "opensubtitles.com": "^1.1.0",
    "tmdb-js-node": "^1.3.2",
    "webtorrent-hybrid": "^5.0.2"
  },
  "devDependencies": {
    "node-pre-gyp": "^0.17.0",
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [
      "node_modules/ffmpeg-static/ffmpeg*",
      "node_modules/ffprobe-static/bin/**/*",
      "public/player/**/*",
      "public/vendor/**/*"
    ],
    "targets": [
      "node18-linux-x64",
      "node18-win-x64",
      "node18-macos-x64"
    ],
    "outputPath": "dist"
  }
}
